/* Paper Ops Theme (QSS) */

QMainWindow, QWidget {
    background-color: #F6F3EE;
    color: #1C1C1C;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
}

QLabel {
    color: #1C1C1C;
}

/* Sidebar */
QWidget#sidebar {
    background-color: #F0ECE6;
    border-right: 1px solid #D9D3C8;
}

QLabel#sidebarTitle {
    color: #2C5DFF;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1px;
}

QLabel#versionStamp {
    color: #5E6167;
    font-family: Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 10px;
    padding: 6px 8px;
}

/* Auto-mode panel */
QFrame#autoModePanel {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 8px;
}

QLabel#autoModeHeader {
    color: #5E6167;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1px;
}

QLabel#autoModeMicrocopy {
    color: #5E6167;
    font-size: 11px;
}

QLabel#autoModeInfo {
    color: #5E6167;
    font-family: Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 10px;
}

QLabel#autoModeError {
    color: #C94B4B;
    font-size: 11px;
}

QPushButton#autoModeToggle {
    background-color: #F0ECE6;
    color: #1C1C1C;
    border: 1px solid #D9D3C8;
    border-radius: 4px;
    padding: 4px 8px;
    font-weight: 700;
}

QPushButton#autoModeToggle:checked {
    background-color: #23A6A6;
    color: #FFFFFF;
    border-color: #23A6A6;
}

QPushButton#autoModeRunOnce {
    background-color: #FFFFFF;
    color: #2C5DFF;
    border: 1px solid #D9D3C8;
    border-radius: 4px;
    padding: 6px 10px;
    font-weight: 700;
}

QPushButton#autoModeRunOnce:hover {
    background-color: rgba(44, 93, 255, 0.08);
}

QListWidget#projectList {
    background: transparent;
    border: none;
}

QListWidget#projectList::item {
    padding: 6px 8px;
    border-radius: 4px;
    color: #5E6167;
}

QListWidget#projectList::item:hover {
    background-color: rgba(44, 93, 255, 0.08);
    color: #2C5DFF;
}

QListWidget#projectList::item:selected {
    background-color: rgba(44, 93, 255, 0.15);
    color: #2C5DFF;
    font-weight: 600;
    border-left: 2px solid #2C5DFF;
}

QPushButton#newProjectButton {
    background-color: #2C5DFF;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 8px 12px;
    font-weight: 600;
}

QPushButton#newProjectButton:hover {
    background-color: #2454E0;
}

/* Roadmap */
QFrame#roadmap {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 8px;
}

QLabel#phaseStep {
    color: #5E6167;
    font-size: 12px;
    font-weight: 600;
}

QLabel#phaseStep[active="true"] {
    color: #2C5DFF;
    font-weight: 700;
}

QLabel#phaseEta {
    color: #5E6167;
    font-size: 11px;
    font-family: Menlo, Consolas, "Liberation Mono", monospace;
}

QLabel#roadmapTimeline {
    color: #5E6167;
    font-weight: 600;
    font-size: 12px;
}

QLabel#roadmapSectionTitle {
    color: #2C5DFF;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
}

QLabel#roadmapSectionItems {
    color: #1C1C1C;
    font-size: 13px;
    line-height: 1.35;
}

/* Agents */
QFrame#agentsGrid {
    background: transparent;
}

QFrame#agentCard {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 8px;
}

QFrame#agentCard[stale="true"] {
    background-color: #FFF5F5;
    border-color: #C94B4B;
}

QLabel#agentName {
    font-weight: 600;
    font-size: 14px;
}

QLabel#agentBadge {
    background-color: #2C5DFF;
    color: #FFFFFF;
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 10px;
}

QLabel#agentPhase {
    color: #5E6167;
    font-weight: 600;
}

QLabel#agentStatus {
    color: #1C1C1C;
    background-color: #E8E2D9;
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
}

QLabel#agentStatus[status="executing"] {
    background-color: #DDF3F3;
    color: #0F766E;
}

QLabel#agentStatus[status="planning"] {
    background-color: #E8EAFD;
    color: #1E40AF;
}

QLabel#agentStatus[status="pinged"] {
    background-color: #E8EAFD;
    color: #1E40AF;
}

QLabel#agentStatus[status="verifying"] {
    background-color: #FEF3C7;
    color: #92400E;
}

QLabel#agentStatus[status="blocked"] {
    background-color: #FDE2E2;
    color: #B91C1C;
}

QLabel#agentStatus[status="error"] {
    background-color: #FEE2E2;
    color: #B91C1C;
}

QLabel#agentStatus[status="completed"] {
    background-color: #DCFCE7;
    color: #166534;
}

QLabel#agentTask {
    color: #5E6167;
    font-size: 12px;
    font-weight: 500;
}

QLabel#agentTask[active="true"] {
    color: #1C1C1C;
    font-weight: 600;
}

QProgressBar#agentProgress {
    background-color: #E8E2D9;
    border: none;
    border-radius: 4px;
    height: 8px;
}

QProgressBar#agentProgress::chunk {
    background-color: #23A6A6;
    border-radius: 4px;
}

QLabel#agentEta {
    color: #5E6167;
    font-size: 11px;
}

QLabel#agentHeartbeat {
    color: #5E6167;
    font-size: 11px;
}

QLabel#agentHeartbeat[stale="true"] {
    color: #C94B4B;
    font-weight: 600;
}

QLabel#agentsEmpty {
    color: #5E6167;
}

QLabel#agentsGroupHeader {
    color: #5E6167;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding-top: 2px;
    padding-bottom: 4px;
}

/* Chatroom */
QWidget#chatroom {
    background-color: #F6F3EE;
    border-left: 1px solid #D9D3C8;
}

QLabel#chatroomTitle {
    color: #2C5DFF;
    font-weight: 600;
    font-size: 12px;
}

QTabWidget#chatroomTabs::pane {
    border: 1px solid #D9D3C8;
    background-color: #FFFFFF;
    top: -1px;
}

QTabBar::tab {
    background-color: #F0ECE6;
    border: 1px solid #D9D3C8;
    padding: 6px 10px;
    margin-right: 4px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    color: #5E6167;
}

QTabBar::tab:selected {
    background-color: #FFFFFF;
    color: #1C1C1C;
    font-weight: 600;
}

QListWidget {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 4px;
}

QListWidget::item {
    padding: 6px 8px;
    color: #1C1C1C;
}

QListWidget#chatGlobalList {
    background-color: #FFFFFF;
}

QListWidget#chatThreadList {
    background-color: #FFFFFF;
}

/* Inputs */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 4px;
    padding: 6px 8px;
    color: #1C1C1C;
}

QLineEdit:focus {
    border-color: #2C5DFF;
}

QLineEdit::placeholder {
    color: #5E6167;
}

QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #D9D3C8;
    border-radius: 4px;
    padding: 6px 8px;
    color: #1C1C1C;
}

QComboBox:hover {
    border-color: #CFC7BA;
}

/* Buttons */
QPushButton {
    background-color: #2C5DFF;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #2454E0;
}

QPushButton:pressed {
    background-color: #1E49C2;
}

/* Scrollbars */
QScrollBar:vertical {
    border: none;
    background: #F6F3EE;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #CFC7BA;
    min-height: 24px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #B9B2A7;
}
